# Dependencies
node_modules/
.pnpm-store/

# Build output
dist/
build/
out/
*.tsbuildinfo

# Rust
target/
**/target/

# Tauri
apps/desktop/src-tauri/gen/
apps/desktop/src-tauri/binaries/
# Mobile Android project is generated by `tauri android init` (regenerable,
# contains build outputs / target / APKs — do not commit, it is ~2GB).
apps/mobile/src-tauri/gen/

# Build artifacts & signing keys
*.apk
*.apk.idsig
*.keystore

# Release artifacts (publish via GitHub Releases instead of source tree)
installers/
portable/

# Server runtime data (assets, exports, logs, embedded DB)
server_data/
apps/server/server_data/

# Environment — never commit secrets. `.env.example` is the canonical template
# and is committed.
.env
.env.local
*.local

# Logs
*.log
logs/

# Claude Code
.claude/

# Editor / OS
.DS_Store
Thumbs.db
.idea/
