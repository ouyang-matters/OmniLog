# ---------------------------------------------------------------------------
# OmniLog Official Hosted Server - Production Environment
# ---------------------------------------------------------------------------

PORT=3000
HOST=0.0.0.0

# MongoDB - point to your server's MongoDB instance.
# Replace with the actual connection string.
MONGODB_URI=mongodb://127.0.0.1:27017
MONGODB_DB=omnilog

DATA_DIR=/data

# Auth - CHANGE THESE before first run.
API_TOKEN=CHANGE-ME-TO-A-LONG-RANDOM-STRING
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE-ME

# CORS - restrict to your official frontend domain in production.
# e.g. https://app.omnilog.io,https://omnilog.io
CORS_ORIGIN=*

RUST_LOG=omnilog_server=info,tower_http=info

# ---------------------------------------------------------------------------
# Stripe billing - fill these in to enable the paid service.
# ---------------------------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=
STRIPE_PRICE_TEAM=
BILLING_RETURN_URL=

# ---------------------------------------------------------------------------
# Registration & email
# ---------------------------------------------------------------------------
REGISTRATION_ENABLED=true
PUBLIC_URL=https://app.omnilog.io
