# ----------------------------------------------------------------------------
# OmniLog Server configuration
# Copy this file to apps/server/.env (or set these as real environment
# variables) before starting the server. Works identically on Windows & Linux.
# ----------------------------------------------------------------------------

# HTTP listener
PORT=3000
HOST=0.0.0.0

# MongoDB connection. May be a local server, a LAN machine, or MongoDB Atlas.
# Examples:
#   mongodb://127.0.0.1:27017
#   mongodb://user:pass@192.168.1.50:27017
#   mongodb+srv://user:pass@cluster0.xxxxx.mongodb.net
#
# Leave EMPTY (or set to "embedded") to use the built-in file-backed storage -
# no database install required. This is what the desktop client's one-click
# local server uses.
MONGODB_URI=mongodb://127.0.0.1:27017
MONGODB_DB=omnilog

# Data directory. Cross-platform - resolved with the Rust standard library, so
# a relative path is fine on both Windows and Linux. assets/, exports/ and
# logs/ are created underneath it automatically.
DATA_DIR=./server_data

# Static auth token. Requests may send `Authorization: Bearer <API_TOKEN>` and
# are treated as the admin user. (User JWT login via /api/auth/login also works.)
# Also used as the JWT signing secret.
API_TOKEN=change-me

# Initial admin account, created on first run if no users exist yet.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin

# CORS. Use * to allow any origin (handy for LAN/self-hosted setups), or a
# comma-separated allowlist, e.g. https://app.example.com,http://localhost:1420
CORS_ORIGIN=*

# Logging (tracing env-filter syntax)
RUST_LOG=omnilog_server=info,tower_http=info

# ----------------------------------------------------------------------------
# Stripe / billing (official hosted service only)
#
# Leave STRIPE_SECRET_KEY empty on self-hosted instances — every /api/billing/*
# route and /api/auth/license then 404, and the desktop client falls back to
# the free experience automatically.
#
# To run as the official paid service, fill in all four:
#
#   STRIPE_SECRET_KEY      - sk_live_... (or sk_test_... while testing)
#   STRIPE_WEBHOOK_SECRET  - whsec_... — copy from the Webhook endpoint you
#                            register in the Stripe Dashboard pointing at
#                            https://<your-host>/api/billing/webhook
#   STRIPE_PRICE_PRO       - price_... for the Pro plan
#   STRIPE_PRICE_TEAM      - price_... for the Team plan
#
# BILLING_RETURN_URL is where Stripe redirects the user after Checkout (success
# OR cancel both bounce back through it). Defaults to the server's own URL.
#
# ----------------------------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=
STRIPE_PRICE_TEAM=
BILLING_RETURN_URL=

# ----------------------------------------------------------------------------
# Superusers (permanently unlimited accounts)
#
# Comma-separated list of usernames. Any user whose login username appears
# here is treated as a permanently-unlimited team-tier account: the license
# endpoint returns an unexpiring license for them, /api/billing/checkout
# refuses to charge them, and they cannot be deleted through the API.
# The role-rank guard also refuses to let non-superusers edit a superuser
# row through PATCH /api/users/:id.
#
# The FIRST entry in the list is the one the server auto-seeds on first
# boot using SUPERUSER_EMAIL, SUPERUSER_DISPLAY_NAME, and SUPERUSER_PASSWORD
# below. Any additional entries are seeded with a random placeholder
# password that the operator must reset via PATCH /api/users/:id before
# the account can log in.
#
# Personal data lives in env vars (not in the repository). Leave any field
# blank to skip seeding it.
# ----------------------------------------------------------------------------
SUPERUSER_USERNAMES=
SUPERUSER_EMAIL=
SUPERUSER_DISPLAY_NAME=
SUPERUSER_PASSWORD=
